# Required: OpenRouter API key
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ponytail minimalism layer. Keeps CrewAI/OpenClaw from overbuilding.
RSPS_PONYTAIL_ENABLED=true
PONYTAIL_DEFAULT_MODE=full

# Pick any OpenRouter model CrewAI/LiteLLM can call.
OPENROUTER_MODEL=openrouter/qwen/qwen3-coder:free

# Optional comma-separated fallback pool. OpenRouter supports at most 3 fallback
# model IDs in one request. Keep these as OpenRouter IDs without "openrouter/".
OPENROUTER_FALLBACK_MODELS=qwen/qwen3-coder:free,openai/gpt-oss-120b:free,qwen/qwen3-next-80b-a3b-instruct:free

# Keep free-provider runs bounded so CrewAI does not stall on long generations.
OPENROUTER_TIMEOUT_SECONDS=75
OPENROUTER_MAX_TOKENS=1400

# One shared OpenRouter key drives all agents. Each agent has a unique primary
# free model and up to 3 fallback IDs.
OPENROUTER_PRODUCER_MODEL=openrouter/openai/gpt-oss-120b:free
OPENROUTER_PRODUCER_FALLBACK_MODELS=openai/gpt-oss-120b:free,nex-agi/nex-n2-pro:free,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_PRODUCER_TEMPERATURE=0.15

OPENROUTER_LEAD_DESIGNER_MODEL=openrouter/qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_LEAD_DESIGNER_FALLBACK_MODELS=qwen/qwen3-next-80b-a3b-instruct:free,nousresearch/hermes-3-llama-3.1-405b:free,google/gemma-4-31b-it:free
OPENROUTER_LEAD_DESIGNER_TEMPERATURE=0.35

OPENROUTER_BACKEND_DEVELOPER_MODEL=openrouter/qwen/qwen3-coder:free
OPENROUTER_BACKEND_DEVELOPER_FALLBACK_MODELS=qwen/qwen3-coder:free,openai/gpt-oss-120b:free,poolside/laguna-m.1:free
OPENROUTER_BACKEND_DEVELOPER_TEMPERATURE=0.12

OPENROUTER_CONTENT_DEVELOPER_MODEL=openrouter/nousresearch/hermes-3-llama-3.1-405b:free
OPENROUTER_CONTENT_DEVELOPER_FALLBACK_MODELS=nousresearch/hermes-3-llama-3.1-405b:free,google/gemma-4-31b-it:free,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_CONTENT_DEVELOPER_TEMPERATURE=0.40

OPENROUTER_CLIENT_DEVELOPER_MODEL=openrouter/poolside/laguna-m.1:free
OPENROUTER_CLIENT_DEVELOPER_FALLBACK_MODELS=poolside/laguna-m.1:free,qwen/qwen3-coder:free,openai/gpt-oss-20b:free
OPENROUTER_CLIENT_DEVELOPER_TEMPERATURE=0.18

OPENROUTER_QA_TESTER_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_QA_TESTER_FALLBACK_MODELS=nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_QA_TESTER_TEMPERATURE=0.10

OPENROUTER_SECURITY_REVIEWER_MODEL=openrouter/nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_SECURITY_REVIEWER_FALLBACK_MODELS=nvidia/nemotron-3-ultra-550b-a55b:free,nvidia/nemotron-3.5-content-safety:free,openai/gpt-oss-120b:free
OPENROUTER_SECURITY_REVIEWER_TEMPERATURE=0.08

OPENROUTER_DOCUMENTATION_WRITER_MODEL=openrouter/google/gemma-4-31b-it:free
OPENROUTER_DOCUMENTATION_WRITER_FALLBACK_MODELS=google/gemma-4-31b-it:free,openai/gpt-oss-20b:free,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_DOCUMENTATION_WRITER_TEMPERATURE=0.20

# Optional: local RSPS repository path.
# Example recommended source: /var/home/Scaar/Desktop/game project/2009scape
RSPS_REPO_PATH=/absolute/path/to/your/rsps

# Optional: build/test commands executed by the QA agent tooling.
# Examples:
# RSPS_BUILD_COMMAND=./gradlew build
# RSPS_TEST_COMMAND=./gradlew test
# 2009scape examples:
# RSPS_BUILD_COMMAND=cd Server && ./mvnw clean package -DskipTests
# RSPS_TEST_COMMAND=cd Server && ./mvnw test
RSPS_BUILD_COMMAND=
RSPS_TEST_COMMAND=

# Coding worker settings. One OpenRouter API key is reused for CrewAI and
# OpenClaw. Duo mode runs rsps-builder and rsps-reviewer in parallel.
RSPS_CODING_CLI=openclaw
# Use openrouter/free for OpenRouter's free-model router, or a concrete
# openrouter/<provider>/<model>:free ID when you want a pinned model.
RSPS_CODING_MODEL=openrouter/free
RSPS_OPENCLAW_BIN=/var/home/Scaar/.local/bin/openclaw
RSPS_OPENCLAW_BUILDER_AGENT=rsps-builder
RSPS_OPENCLAW_REVIEWER_AGENT=rsps-reviewer
RSPS_OPENCLAW_RSPS_BUILDER_MODEL=openrouter/free
RSPS_OPENCLAW_RSPS_REVIEWER_MODEL=openrouter/free
RSPS_OPENCLAW_TIMEOUT_SECONDS=900
OPENCLAW_CLI_CMD=
RSPS_DUO_MODE=true
RSPS_DUO_USE_WORKTREES=true
RSPS_DUO_KEEP_WORKTREES=false
RSPS_WORKER_TIMEOUT_SECONDS=900
RSPS_WORKER_DRY_RUN=false

# Git/GitHub sync. When enabled, successful work orders commit their changes.
# Push requires an origin remote and `gh auth login`/git credentials.
RSPS_GIT_COMMIT_AFTER_WORK=true
RSPS_GIT_PUSH_AFTER_WORK=false
RSPS_AGENT_WORKTREE_ROOT=

# Safety gate for direct repo modification. Keep false until you are ready for
# autonomous coding cycles. Manual rsps-worker runs also require this to be true.
RSPS_ALLOW_AUTONOMOUS=false
